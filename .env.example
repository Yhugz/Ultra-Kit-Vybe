# ═══ Vybe Project — Environment Variables ═══
# Copier ce fichier en .env.local et remplir les valeurs

# Site
NEXT_PUBLIC_SITE_URL=           # URL publique (https://www.exemple.fr)
NEXT_PUBLIC_SITE_NAME=          # Nom du site / client

# Analytics
NEXT_PUBLIC_GA_ID=              # Google Analytics 4 (G-XXXXXXXXXX)

# Contact
RESEND_API_KEY=                 # API key Resend (formulaire de contact)
CONTACT_EMAIL=                  # Email de réception des messages

# Social
NEXT_PUBLIC_INSTAGRAM_URL=      # URL profil Instagram
NEXT_PUBLIC_FACEBOOK_URL=       # URL page Facebook
NEXT_PUBLIC_WHATSAPP_NUMBER=    # Numéro WhatsApp (format international)

# Maps (si carte intégrée)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=    # API key Google Maps
